# Cloudflare static-asset headers.
# Only content-hashed build output gets immutable long-cache; HTML is left to
# Cloudflare's default (revalidated) so new deploys always propagate.

# Content-hashed JS/CSS — safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Stable media files — cache for a month.
/*.png
  Cache-Control: public, max-age=2592000
/*.jpeg
  Cache-Control: public, max-age=2592000
/*.jpg
  Cache-Control: public, max-age=2592000
/*.svg
  Cache-Control: public, max-age=2592000
/*.webp
  Cache-Control: public, max-age=2592000
/*.ico
  Cache-Control: public, max-age=2592000

# AI/SEO discovery files — cache for a day.
/robots.txt
  Cache-Control: public, max-age=86400
/sitemap.xml
  Cache-Control: public, max-age=86400
/llms.txt
  Cache-Control: public, max-age=86400
/llms-full.txt
  Cache-Control: public, max-age=86400
/ai.txt
  Cache-Control: public, max-age=86400

# Security and privacy headers for every response.
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=(), browsing-topics=()
  Strict-Transport-Security: max-age=31536000
